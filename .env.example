# Copy to .env.local and fill in the values from the Neon dashboard.
# .env.local is gitignored; .env.example is committed as a placeholder.

# Pooled connection string — used by the app runtime (route handlers).
DATABASE_URL="postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require"

# Unpooled/direct connection — used by Drizzle Kit for migrations.
DATABASE_URL_UNPOOLED="postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/<db>?sslmode=require"

# Better Auth session secret — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="<32+ char random string>"
# The canonical base URL the auth handler is served from.
BETTER_AUTH_URL="http://localhost:3000"

# Resend — API key for magic link email delivery. Leave empty in dev to
# log magic link URLs to the server console instead.
RESEND_API_KEY=""
# Sender address used when Resend is configured.
AUTH_EMAIL_FROM="Assymo <auth@assymo.be>"
